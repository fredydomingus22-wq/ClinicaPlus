    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "zod": "^3.22.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
