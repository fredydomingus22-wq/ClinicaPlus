# ──────────────────────────────────────────────────────────────────────────────
# ClinicaPlus API — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Transaction mode (port 6543) — used by Prisma at runtime (connection pooling)
DATABASE_URL="postgresql://postgres.xyjuprkouwkxkrdkyvup:MalhadoM11!@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used ONLY by Prisma migrate (no pooler)
DIRECT_URL="postgresql://postgres.xyjuprkouwkxkrdkyvup:MalhadoM11!@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"
# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="<64+ character random string>"

# Must be DIFFERENT from JWT_SECRET
# Generate with: openssl rand -base64 64
JWT_REFRESH_SECRET="<64+ character random string — different from above>"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend ──────────────────────────────────────────────────────────────────
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
# Dev:  re_test_...  (sandbox — only sends to verified addresses)
# Prod: re_live_...  (requires verified domain in Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Multi-tenancy (Subdomínios) ───────────────────────────────────────────────
# Domínio base para tenants por subdomínio (ex: nutrimacho.clinicaplus.ao)
# Opcional — se não definido, wildcard CORS para subdomínios fica desactivado
# TENANT_BASE_DOMAIN=clinicaplus.ao

# ── Infrastructure (V2) ──────────────────────────────────────────────────────
# Upstash Redis URL (format: rediss://default:pass@host:port)
REDIS_URL=redis://localhost:6379

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_TOKEN=<random token min 8 chars>
ALERT_EMAIL=admin@clinicaplus.local
