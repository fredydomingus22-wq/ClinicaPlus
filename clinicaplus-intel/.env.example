# Porta do serviço FastAPI
PORT=8001

# Conexão com a base de dados (Leitura rápida)
# IMPORTANTE: Usar a Connection String do Supabase com o PgBouncer (Transaction Mode) - Porta 6543
DATABASE_URL=postgresql://user:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Configurações do Evolution API (WhatsApp)
EVOLUTION_API_URL=https://evolution.seuservidor.com
EVOLUTION_API_KEY=sua_api_key_global
EVOLUTION_WEBHOOK_SECRET=segredo_hmac_para_validar_webhooks

# Integração Interna (Delegação de Escritas)
TS_API_URL=http://api.clinica.internal:3001
TS_API_INTERNAL_KEY=chave_secreta_partilhada_com_a_api_ts
